COMPOSE_PROJECT_NAME=work-tools

# ===== Mongo =====
MONGO_IMAGE=mongo:7
MONGO_CONTAINER_NAME=work-tools-mongo
MONGO_INTERNAL_PORT=27017
MONGO_PORT=27017
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin
MONGO_APP_DB=workTools
MONGO_APP_USER=workTools
MONGO_APP_PASSWORD=workTools
MONGO_APP_COLLECTION=workTools
MONGO_DATA_DIR=./.data/mongo/data
MONGO_DATA_TARGET_DIR=/data/db
MONGO_INITDB_TARGET_DIR=/docker-entrypoint-initdb.d

# ===== ClickHouse =====
CLICKHOUSE_IMAGE=clickhouse/clickhouse-server:25.11
CLICKHOUSE_CONTAINER_NAME=work-tools-clickhouse
CLICKHOUSE_HTTP_INTERNAL_PORT=8123
CLICKHOUSE_TCP_INTERNAL_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_TCP_PORT=9000
CLICKHOUSE_DB=workTools
CLICKHOUSE_USER=workTools
CLICKHOUSE_PASSWORD=workTools
CLICKHOUSE_DATA_DIR=./.data/clickhouse/data
CLICKHOUSE_LOG_DIR=./.data/clickhouse/logs
CLICKHOUSE_DATA_TARGET_DIR=/var/lib/clickhouse
CLICKHOUSE_LOG_TARGET_DIR=/var/log/clickhouse-server
CLICKHOUSE_CONFIG_TARGET_DIR=/etc/clickhouse-server/config.d
CLICKHOUSE_INITDB_TARGET_DIR=/docker-entrypoint-initdb.d

# ===== NATS =====
NATS_CONTAINER_NAME=work-tools-nats
NATS_SERVER_NAME=work-tools-nats
NATS_INTERNAL_PORT=4222
NATS_MONITOR_INTERNAL_PORT=8222
NATS_PORT=4222
NATS_MONITOR_PORT=8222
NATS_STORE_DIR=/data/jetstream
NATS_DATA_DIR=./.data/nats/data
